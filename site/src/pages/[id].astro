---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getKits } from '../data/kits'

export function getStaticPaths() {
  const kits = getKits()
  return kits.map(kit => ({
    params: { id: kit.id },
    props: { kit },
  }))
}

const { kit } = Astro.props

// Fetch README at build time — raw.githubusercontent.com has no rate limit
let readme = ''
if (kit.repoUrl) {
  const repoPath = kit.repoUrl.replace('https://github.com/', '')
  const branch = kit.defaultBranch || 'main'
  try {
    let res = await fetch(`https://raw.githubusercontent.com/${repoPath}/${branch}/README.md`)
    if (!res.ok && branch === 'main') {
      res = await fetch(`https://raw.githubusercontent.com/${repoPath}/master/README.md`)
    }
    if (res.ok) {
      readme = await res.text()
    }
  } catch {}
}
---

<BaseLayout title={`${kit.name} — ClawClawGo`} description={kit.description}>
  <div id="kit-page-root" data-kit={JSON.stringify(kit)} data-readme={readme}></div>
  <script>
    import { createElement } from 'react'
    import { createRoot } from 'react-dom/client'
    import KitPage from '../components/KitPage'

    const el = document.getElementById('kit-page-root')!
    const kit = JSON.parse(el.dataset.kit!)
    const readme = el.dataset.readme || ''
    createRoot(el).render(createElement(KitPage, { kit, readme }))
  </script>
</BaseLayout>
