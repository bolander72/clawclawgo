{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RipperClaw",
  "version": "0.1.0",
  "identifier": "com.ripperclaw.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RipperClaw",
        "width": 1100,
        "height": 750,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "trayIcon": {
      "tooltip": "RipperClaw",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
